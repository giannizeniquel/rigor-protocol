{
  "colors": {
    "background": {
      "primary": "#0A0A0A",
      "secondary": "#1C1C1C",
      "tertiary": "#2A2A2A"
    },
    "text": {
      "primary": "#F2F2F2",
      "muted": "#A3A3A3"
    },
    "accent": {
      "primary": "#1E3A8A"
    },
    "diagram": {
      "stroke": "#F2F2F2",
      "accent": "#1E3A8A"
    }
  },
  "typography": {
    "fontFamily": {
      "heading": "'IBM Plex Serif', 'Georgia', serif",
      "body": "'Inter', -apple-system, system-ui, sans-serif",
      "mono": "'JetBrains Mono', 'Consolas', monospace"
    },
    "fontSize": {
      "h1": "3.5rem",
      "h2": "2.25rem",
      "h3": "1.5rem",
      "body": "1rem",
      "caption": "0.875rem"
    },
    "fontWeight": {
      "heading": "600",
      "body": "400",
      "muted": "400"
    },
    "letterSpacing": {
      "wordmark": "0.08em",
      "heading": "0.02em",
      "body": "0",
      "caption": "0.01em"
    },
    "lineHeight": {
      "heading": "1.2",
      "body": "1.6",
      "caption": "1.4"
    }
  },
  "spacing": {
    "section": "96px",
    "block": "48px",
    "element": "24px",
    "inline": "16px",
    "tight": "8px"
  },
  "layout": {
    "maxWidth": "1280px",
    "columns": 12,
    "gutter": "24px",
    "margin": "48px"
  },
  "borderRadius": {
    "none": "0",
    "minimal": "2px"
  },
  "borderWidth": {
    "thin": "1px",
    "diagram": "1.5px"
  },
  "motion": {
    "duration": {
      "fast": "150ms",
      "base": "250ms",
      "slow": "400ms"
    },
    "easing": {
      "linear": "linear",
      "standard": "cubic-bezier(0.4, 0.0, 0.2, 1)"
    }
  }
