---
import { getLangFromUrl, useTranslations } from '../i18n/utils';

const lang = getLangFromUrl(Astro.url);
const t = useTranslations(lang);
---

<section class="section section--ruled">
  <div class="container">
    <div class="section-header">
      <span class="section-num">12</span>
      <span class="section-rule"></span>
    </div>
    <h2>{t('protocolVsPrompt.title')}</h2>

    <div class="table-wrapper">
      <table>
        <thead>
          <tr>
            <th class="col-aspect">{t('protocolVsPrompt.table.head.aspect')}</th>
            <th class="col-prompt">{t('protocolVsPrompt.table.head.prompt')}</th>
            <th class="col-protocol">{t('protocolVsPrompt.table.head.protocol')}</th>
          </tr>
        </thead>
        <tbody>
          <tr>
            <td><strong>{t('protocolVsPrompt.table.approach')}</strong></td>
            <td>{t('protocolVsPrompt.table.approach.prompt')}</td>
            <td class="protocol-col">{t('protocolVsPrompt.table.approach.protocol')}</td>
          </tr>
          <tr>
            <td><strong>{t('protocolVsPrompt.table.method')}</strong></td>
            <td>{t('protocolVsPrompt.table.method.prompt')}</td>
            <td class="protocol-col">{t('protocolVsPrompt.table.method.protocol')}</td>
          </tr>
          <tr>
            <td><strong>{t('protocolVsPrompt.table.control')}</strong></td>
            <td>{t('protocolVsPrompt.table.control.prompt')}</td>
            <td class="protocol-col">{t('protocolVsPrompt.table.control.protocol')}</td>
          </tr>
          <tr>
            <td><strong>{t('protocolVsPrompt.table.validation')}</strong></td>
            <td>{t('protocolVsPrompt.table.validation.prompt')}</td>
            <td class="protocol-col">{t('protocolVsPrompt.table.validation.protocol')}</td>
          </tr>
          <tr>
            <td><strong>{t('protocolVsPrompt.table.output')}</strong></td>
            <td>{t('protocolVsPrompt.table.output.prompt')}</td>
            <td class="protocol-col">{t('protocolVsPrompt.table.output.protocol')}</td>
          </tr>
        </tbody>
      </table>
    </div>

    <p class="distinction-statement">{t('protocolVsPrompt.statement')}</p>
  </div>
</section>

<style>
  .section--ruled {
    padding-top: var(--spacing-section);
    padding-bottom: var(--spacing-section);
  }

  .section-header {
    display: flex;
    align-items: center;
    gap: var(--spacing-inline);
    margin-bottom: var(--spacing-block);
  }

  .section-num {
    font-family: var(--font-mono);
    font-size: 0.7rem;
    color: var(--color-text-muted);
    letter-spacing: 0.14em;
    flex-shrink: 0;
    line-height: 1;
  }

  .section-rule {
    display: block;
    width: 100%;
    height: 1px;
    background-color: var(--color-bg-tertiary);
  }

  h2 {
    font-family: var(--font-heading);
    font-size: var(--text-h2);
    font-weight: var(--weight-heading);
    letter-spacing: var(--tracking-heading);
    margin-bottom: var(--spacing-block);
  }

  .table-wrapper {
    overflow-x: auto;
    margin-bottom: var(--spacing-block);
    border: 1px solid var(--color-bg-tertiary);
  }

  table {
    width: 100%;
    border-collapse: collapse;
    font-size: var(--text-caption);
  }

  th {
    font-family: var(--font-mono);
    font-size: 0.65rem;
    font-weight: 400;
    letter-spacing: 0.1em;
    text-transform: uppercase;
    color: var(--color-text-muted);
    background-color: var(--color-bg-secondary);
    padding: var(--spacing-inline) var(--spacing-element);
    text-align: left;
    border-bottom: 1px solid var(--color-bg-tertiary);
  }

  th.col-protocol {
    color: var(--color-text-primary);
    border-bottom: 2px solid var(--color-accent);
  }

  td {
    padding: var(--spacing-element);
    border-bottom: 1px solid var(--color-bg-tertiary);
    vertical-align: top;
    line-height: var(--leading-body);
    color: var(--color-text-muted);
  }

  tr:last-child td {
    border-bottom: none;
  }

  td strong {
    font-family: var(--font-mono);
    font-weight: 400;
    font-size: var(--text-caption);
    color: var(--color-text-primary);
    letter-spacing: 0.04em;
  }

  td.protocol-col {
    border-left: 2px solid var(--color-accent);
    color: var(--color-text-primary);
  }

  .distinction-statement {
    font-weight: var(--weight-heading);
    max-width: 720px;
    border-left: 2px solid var(--color-accent);
    padding-left: var(--spacing-inline);
    margin-bottom: 0;
  }
</style>
