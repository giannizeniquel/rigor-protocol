---
import { getLangFromUrl, useTranslations } from '../i18n/utils';

const lang = getLangFromUrl(Astro.url);
const t = useTranslations(lang);
---

<section class="hero">
  <div class="container">
    <div class="hero-grid">

      <div class="hero-content">
        <p class="hero-label">{t('hero.subtitle')}</p>
        <h1 class="hero-wordmark">RIGOR</h1>
        <p class="hero-tertiary">{t('hero.tertiary')}</p>
        <p class="hero-optional">{t('hero.optional')}</p>
        <a
          href={lang === 'es' ? 'https://rigor-docs.pages.dev/es/' : 'https://rigor-docs.pages.dev/'}
          class="hero-cta"
          target="_blank"
          rel="noopener noreferrer"
        >
          {t('hero.cta')}
        </a>
      </div>

      <div class="hero-diagram" aria-hidden="true">
        <p class="diagram-fig">FIG. 01 — Architectural Position</p>
        <div class="diagram-box">
          <svg viewBox="0 0 320 380" fill="none" xmlns="http://www.w3.org/2000/svg">
            <!-- Human Intent -->
            <rect x="40" y="16" width="240" height="44" stroke="#F2F2F2" stroke-width="1.5"/>
            <text x="160" y="43" fill="#F2F2F2" font-family="'Space Grotesk', sans-serif" font-size="11" text-anchor="middle" letter-spacing="0.04em">
              {t('protocolModel.flow.humanIntent')}
            </text>

            <!-- Arrow 1 -->
            <path d="M160 60 L160 82" stroke="#A3A3A3" stroke-width="1"/>
            <polygon points="160,82 155,74 165,74" fill="#A3A3A3"/>

            <!-- Rigor Specification (accented) -->
            <rect x="20" y="86" width="280" height="44" stroke="#1E3A8A" stroke-width="2"/>
            <rect x="20" y="86" width="4" height="44" fill="#1E3A8A"/>
            <text x="168" y="113" fill="#F2F2F2" font-family="'Space Grotesk', sans-serif" font-size="11" text-anchor="middle" letter-spacing="0.04em">
              {t('protocolModel.flow.specification')}
            </text>

            <!-- Arrow 2 -->
            <path d="M160 130 L160 152" stroke="#A3A3A3" stroke-width="1"/>
            <polygon points="160,152 155,144 165,144" fill="#A3A3A3"/>

            <!-- AI Generation -->
            <rect x="60" y="156" width="200" height="44" stroke="#F2F2F2" stroke-width="1.5"/>
            <text x="160" y="183" fill="#F2F2F2" font-family="'Space Grotesk', sans-serif" font-size="11" text-anchor="middle" letter-spacing="0.04em">
              {t('protocolModel.flow.generation')}
            </text>

            <!-- Arrow 3 -->
            <path d="M160 200 L160 222" stroke="#A3A3A3" stroke-width="1"/>
            <polygon points="160,222 155,214 165,214" fill="#A3A3A3"/>

            <!-- Structural Validation (accented) -->
            <rect x="40" y="226" width="240" height="44" stroke="#1E3A8A" stroke-width="2"/>
            <rect x="40" y="226" width="4" height="44" fill="#1E3A8A"/>
            <text x="168" y="253" fill="#F2F2F2" font-family="'Space Grotesk', sans-serif" font-size="11" text-anchor="middle" letter-spacing="0.04em">
              {t('protocolModel.flow.validation')}
            </text>

            <!-- Arrow 4 -->
            <path d="M160 270 L160 292" stroke="#A3A3A3" stroke-width="1"/>
            <polygon points="160,292 155,284 165,284" fill="#A3A3A3"/>

            <!-- Runtime Execution -->
            <rect x="60" y="296" width="200" height="44" stroke="#F2F2F2" stroke-width="1.5"/>
            <text x="160" y="323" fill="#F2F2F2" font-family="'Space Grotesk', sans-serif" font-size="11" text-anchor="middle" letter-spacing="0.04em">
              {t('protocolModel.flow.execution')}
            </text>
          </svg>
        </div>
        <p class="diagram-caption">{t('protocolModel.diagramDescription')}</p>
      </div>

    </div>
  </div>
</section>

<style>
  .hero {
    padding-top: 120px;
    padding-bottom: var(--spacing-section);
    min-height: 90vh;
    display: flex;
    align-items: center;
    border-bottom: 1px solid var(--color-bg-tertiary);
  }

  .hero-grid {
    display: grid;
    grid-template-columns: 1fr 420px;
    gap: var(--spacing-section);
    align-items: center;
  }

  /* LEFT: content */
  .hero-content {
    display: flex;
    flex-direction: column;
    align-items: flex-start;
  }

  .hero-label {
    font-family: var(--font-mono);
    font-size: var(--text-caption);
    color: var(--color-accent);
    letter-spacing: 0.12em;
    text-transform: uppercase;
    margin-bottom: var(--spacing-block);
    border-left: 2px solid var(--color-accent);
    padding-left: var(--spacing-inline);
    line-height: 1;
  }

  .hero-wordmark {
    font-family: var(--font-heading);
    font-size: clamp(5rem, 10vw, 9rem);
    font-weight: 600;
    letter-spacing: 0.12em;
    line-height: 1;
    margin-bottom: var(--spacing-block);
    color: var(--color-text-primary);
  }

  .hero-tertiary {
    font-size: 1.125rem;
    color: var(--color-text-primary);
    line-height: var(--leading-body);
    margin-bottom: var(--spacing-tight);
    max-width: 500px;
  }

  .hero-optional {
    font-size: var(--text-body);
    color: var(--color-text-muted);
    margin-bottom: var(--spacing-block);
    max-width: 500px;
  }

  .hero-cta {
    display: inline-block;
    font-family: var(--font-heading);
    font-size: var(--text-body);
    font-weight: var(--weight-heading);
    color: var(--color-text-primary);
    text-decoration: none;
    letter-spacing: 0.04em;
    padding-bottom: 3px;
    border-bottom: 1px solid var(--color-accent);
    transition: opacity var(--duration-fast) var(--easing-linear);
  }

  .hero-cta:hover {
    opacity: 0.75;
  }

  /* RIGHT: diagram */
  .hero-diagram {
    display: flex;
    flex-direction: column;
  }

  .diagram-fig {
    font-family: var(--font-mono);
    font-size: 0.7rem;
    color: var(--color-text-muted);
    letter-spacing: 0.1em;
    text-transform: uppercase;
    margin-bottom: var(--spacing-inline);
  }

  .diagram-box {
    border: 1px solid var(--color-bg-tertiary);
    background-color: var(--color-bg-secondary);
    padding: var(--spacing-element);
    display: flex;
    justify-content: center;
    align-items: center;
  }

  .diagram-box svg {
    width: 100%;
    max-width: 320px;
    height: auto;
  }

  .diagram-caption {
    font-family: var(--font-mono);
    font-size: 0.7rem;
    color: var(--color-text-muted);
    margin-top: var(--spacing-inline);
    line-height: var(--leading-caption);
    margin-bottom: 0;
  }

  /* Mobile */
  @media (max-width: 900px) {
    .hero {
      padding-top: 100px;
      min-height: auto;
      align-items: flex-start;
    }

    .hero-grid {
      grid-template-columns: 1fr;
      gap: var(--spacing-block);
    }

    .hero-wordmark {
      font-size: clamp(4rem, 15vw, 6rem);
    }

    .hero-diagram {
      display: none;
    }
  }
</style>
