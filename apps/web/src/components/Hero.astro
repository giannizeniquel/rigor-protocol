---
import { getLangFromUrl, useTranslations } from '../i18n/utils';

const lang = getLangFromUrl(Astro.url);
const t = useTranslations(lang);
---

<section class="hero">
  <div class="container">
    <h1 class="hero-logo-container">
      <img 
        src="/assets/logo/rigor-logo-default-lg.svg" 
        alt="RIGOR Protocol" 
        class="hero-logo"
        width="304" 
        height="144"
      />
    </h1>
    <h2>{t('hero.subtitle')}</h2>
    <p class="tertiary">{t('hero.tertiary')}</p>
    <p class="optional muted">{t('hero.optional')}</p>
    <div class="hero-icon">
      <img 
        src="/assets/icons/rigor-icon-brackets.png" 
        alt="RIGOR" 
        width="48" 
        height="48"
      />
    </div>
    <a href="https://docs.rigor.dev" class="cta">{t('hero.cta')}</a>
  </div>
</section>

<style>
  .hero {
    padding: 80px 0;
    min-height: 60vh;
    display: flex;
    align-items: center;
  }

  .hero-logo-container {
    margin-bottom: var(--spacing-element);
  }

  .hero-logo {
    max-width: 100%;
    height: auto;
  }

  h2 {
    font-family: var(--font-heading);
    font-size: var(--text-h2);
    font-weight: var(--weight-heading);
    margin-bottom: var(--spacing-element);
  }

  .tertiary {
    font-size: var(--text-body);
    color: var(--color-text-primary);
    margin-bottom: var(--spacing-tight);
    max-width: 480px;
  }

  .optional {
    font-size: var(--text-body);
    color: var(--color-text-muted);
    margin-bottom: var(--spacing-block);
  }

  .cta {
    display: inline-block;
    color: var(--color-text-primary);
    text-decoration: none;
    border-bottom: 1px solid var(--color-accent);
    padding-bottom: 2px;
    transition: opacity 150ms linear;
  }

  .cta:hover {
    opacity: 0.8;
  }

  .hero-icon {
    margin-bottom: var(--spacing-block);
  }

  .hero-icon img {
    width: 48px;
    height: 48px;
  }
</style>
