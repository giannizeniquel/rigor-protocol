---
import { getLangFromUrl, useTranslations } from '../i18n/utils';

const lang = getLangFromUrl(Astro.url);
const t = useTranslations(lang);
---

<section class="section section--ruled">
  <div class="container">
    <div class="section-header">
      <span class="section-num">08</span>
      <span class="section-rule"></span>
    </div>

    <div class="access-block">
      <div class="access-inner">
        <h2>{t('specificationAccess.title')}</h2>
        <p class="body-text">{t('specificationAccess.body')}</p>
        <div class="links">
          <a
            href={lang === 'es' ? 'https://rigor-docs.pages.dev/es/' : 'https://rigor-docs.pages.dev/'}
            class="cta-primary"
            target="_blank"
            rel="noopener noreferrer"
          >
            {t('specificationAccess.cta')}
          </a>
          <a
            href="https://github.com/giannizeniquel/rigor-protocol"
            class="cta-secondary"
            target="_blank"
            rel="noopener noreferrer"
          >
            {t('specificationAccess.secondary')}
          </a>
        </div>
      </div>
      <div class="access-aside" aria-hidden="true">
        <p class="spec-label">Specification</p>
        <p class="spec-version">v0.1</p>
      </div>
    </div>
  </div>
</section>

<style>
  .section--ruled {
    padding-top: var(--spacing-section);
    padding-bottom: var(--spacing-section);
  }

  .section-header {
    display: flex;
    align-items: center;
    gap: var(--spacing-inline);
    margin-bottom: var(--spacing-block);
  }

  .section-num {
    font-family: var(--font-mono);
    font-size: 0.7rem;
    color: var(--color-text-muted);
    letter-spacing: 0.14em;
    flex-shrink: 0;
    line-height: 1;
  }

  .section-rule {
    display: block;
    width: 100%;
    height: 1px;
    background-color: var(--color-bg-tertiary);
  }

  .access-block {
    display: grid;
    grid-template-columns: 1fr auto;
    align-items: stretch;
    border: 1px solid var(--color-bg-tertiary);
    border-left: 2px solid var(--color-accent);
  }

  .access-inner {
    padding: var(--spacing-block);
  }

  h2 {
    font-family: var(--font-heading);
    font-size: var(--text-h2);
    font-weight: var(--weight-heading);
    letter-spacing: var(--tracking-heading);
    margin-bottom: var(--spacing-element);
  }

  .body-text {
    color: var(--color-text-muted);
    max-width: 560px;
    margin-bottom: var(--spacing-block);
    line-height: var(--leading-body);
  }

  .links {
    display: flex;
    gap: var(--spacing-block);
    flex-wrap: wrap;
    align-items: center;
  }

  .cta-primary {
    display: inline-block;
    font-family: var(--font-heading);
    font-size: var(--text-body);
    font-weight: var(--weight-heading);
    color: var(--color-text-primary);
    text-decoration: none;
    letter-spacing: 0.04em;
    padding-bottom: 3px;
    border-bottom: 1px solid var(--color-accent);
    transition: opacity var(--duration-fast) var(--easing-linear);
  }

  .cta-primary:hover {
    opacity: 0.75;
  }

  .cta-secondary {
    display: inline-block;
    font-size: var(--text-caption);
    color: var(--color-text-muted);
    text-decoration: none;
    padding-bottom: 2px;
    border-bottom: 1px solid var(--color-bg-tertiary);
    transition: color var(--duration-fast) var(--easing-linear),
                border-color var(--duration-fast) var(--easing-linear);
  }

  .cta-secondary:hover {
    color: var(--color-text-primary);
    border-color: var(--color-text-muted);
  }

  /* Right aside: version info */
  .access-aside {
    display: flex;
    flex-direction: column;
    justify-content: center;
    align-items: center;
    padding: var(--spacing-block);
    border-left: 1px solid var(--color-bg-tertiary);
    min-width: 120px;
    gap: var(--spacing-tight);
    background-color: var(--color-bg-secondary);
  }

  .spec-label {
    font-family: var(--font-mono);
    font-size: 0.65rem;
    letter-spacing: 0.12em;
    text-transform: uppercase;
    color: var(--color-text-muted);
    margin-bottom: 0;
  }

  .spec-version {
    font-family: var(--font-heading);
    font-size: var(--text-h3);
    font-weight: var(--weight-heading);
    color: var(--color-text-primary);
    letter-spacing: var(--tracking-heading);
    margin-bottom: 0;
  }

  /* Mobile */
  @media (max-width: 640px) {
    .access-block {
      grid-template-columns: 1fr;
    }

    .access-aside {
      border-left: none;
      border-top: 1px solid var(--color-bg-tertiary);
      flex-direction: row;
      justify-content: flex-start;
    }
  }
</style>
