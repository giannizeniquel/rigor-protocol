---
import { getLangFromUrl, useTranslations } from '../i18n/utils';

const lang = getLangFromUrl(Astro.url);
const t = useTranslations(lang);
---

<section class="section section--ruled">
  <div class="container">
    <div class="section-header">
      <span class="section-num">05</span>
      <span class="section-rule"></span>
    </div>
    <h2>{t('structuralPositioning.title')}</h2>
    <p class="intro">{t('structuralPositioning.intro')}</p>

    <div class="table-wrapper">
      <table>
        <thead>
          <tr>
            <th class="col-system">{t('structuralPositioning.table.head.system')}</th>
            <th class="col-what">{t('structuralPositioning.table.head.whatItDoes')}</th>
            <th class="col-rigor">{t('structuralPositioning.table.head.rigorDoes')}</th>
          </tr>
        </thead>
        <tbody>
          <tr>
            <td>
              <strong>{t('structuralPositioning.table.workflow.name')}</strong>
              <span class="alt-text">{t('structuralPositioning.table.workflow.alt')}</span>
            </td>
            <td>{t('structuralPositioning.table.workflow.what')}</td>
            <td class="rigor-col">{t('structuralPositioning.table.workflow.rigor')}</td>
          </tr>
          <tr>
            <td>
              <strong>{t('structuralPositioning.table.iac.name')}</strong>
              <span class="alt-text">{t('structuralPositioning.table.iac.alt')}</span>
            </td>
            <td>{t('structuralPositioning.table.iac.what')}</td>
            <td class="rigor-col">{t('structuralPositioning.table.iac.rigor')}</td>
          </tr>
          <tr>
            <td>
              <strong>{t('structuralPositioning.table.static.name')}</strong>
              <span class="alt-text">{t('structuralPositioning.table.static.alt')}</span>
            </td>
            <td>{t('structuralPositioning.table.static.what')}</td>
            <td class="rigor-col">{t('structuralPositioning.table.static.rigor')}</td>
          </tr>
          <tr>
            <td>
              <strong>{t('structuralPositioning.table.dsl.name')}</strong>
            </td>
            <td>{t('structuralPositioning.table.dsl.what')}</td>
            <td class="rigor-col">{t('structuralPositioning.table.dsl.rigor')}</td>
          </tr>
        </tbody>
      </table>
    </div>

    <p class="positioning-statement">{t('structuralPositioning.statement')}</p>
  </div>
</section>

<style>
  .section--ruled {
    padding-top: var(--spacing-section);
    padding-bottom: var(--spacing-section);
  }

  .section-header {
    display: flex;
    align-items: center;
    gap: var(--spacing-inline);
    margin-bottom: var(--spacing-block);
  }

  .section-num {
    font-family: var(--font-mono);
    font-size: 0.7rem;
    color: var(--color-text-muted);
    letter-spacing: 0.14em;
    flex-shrink: 0;
    line-height: 1;
  }

  .section-rule {
    display: block;
    width: 100%;
    height: 1px;
    background-color: var(--color-bg-tertiary);
  }

  h2 {
    font-family: var(--font-heading);
    font-size: var(--text-h2);
    font-weight: var(--weight-heading);
    letter-spacing: var(--tracking-heading);
    margin-bottom: var(--spacing-element);
  }

  .intro {
    color: var(--color-text-muted);
    max-width: 720px;
    margin-bottom: var(--spacing-block);
  }

  .table-wrapper {
    overflow-x: auto;
    margin-bottom: var(--spacing-block);
    border: 1px solid var(--color-bg-tertiary);
  }

  table {
    width: 100%;
    border-collapse: collapse;
    font-size: var(--text-caption);
  }

  th {
    font-family: var(--font-mono);
    font-size: 0.65rem;
    font-weight: 400;
    letter-spacing: 0.1em;
    text-transform: uppercase;
    color: var(--color-text-muted);
    background-color: var(--color-bg-secondary);
    padding: var(--spacing-inline) var(--spacing-element);
    text-align: left;
    border-bottom: 1px solid var(--color-bg-tertiary);
  }

  /* Accent on RIGOR column header */
  th.col-rigor {
    color: var(--color-text-primary);
    border-bottom: 2px solid var(--color-accent);
  }

  td {
    padding: var(--spacing-element);
    border-bottom: 1px solid var(--color-bg-tertiary);
    vertical-align: top;
    line-height: var(--leading-body);
    color: var(--color-text-muted);
  }

  tr:last-child td {
    border-bottom: none;
  }

  td strong {
    display: block;
    font-family: var(--font-heading);
    font-weight: var(--weight-heading);
    color: var(--color-text-primary);
    margin-bottom: 4px;
  }

  .alt-text {
    font-size: 0.75rem;
    color: var(--color-text-muted);
    display: block;
  }

  /* Accent on RIGOR column cells */
  td.rigor-col {
    border-left: 2px solid var(--color-accent);
    color: var(--color-text-primary);
  }

  .positioning-statement {
    font-weight: var(--weight-heading);
    max-width: 720px;
    border-left: 2px solid var(--color-accent);
    padding-left: var(--spacing-inline);
    margin-bottom: 0;
  }
</style>
