---
import { getLangFromUrl, useTranslations } from '../i18n/utils';

const lang = getLangFromUrl(Astro.url);
const t = useTranslations(lang);
---

<footer class="footer">
  <div class="container">
    <div class="footer-top">
      <div class="footer-brand">
        <span class="brand-word">{t('footer.brand')}</span>
        <span class="brand-tag">{t('footer.tagline')}</span>
      </div>
      <div class="footer-meta">
        <span class="spec-version">{t('footer.version')}</span>
      </div>
    </div>

    <div class="footer-bottom">
      <nav class="footer-nav" aria-label="Footer navigation">
        <a
          href={lang === 'es' ? 'https://rigor-docs.pages.dev/es/' : 'https://rigor-docs.pages.dev/'}
          class="footer-link"
          target="_blank"
          rel="noopener noreferrer"
        >
          {t('footer.specification')}
        </a>
        <a
          href="https://github.com/giannizeniquel/rigor-protocol"
          class="footer-link"
          target="_blank"
          rel="noopener noreferrer"
        >
          {t('footer.github')}
        </a>
        <span class="footer-divider" aria-hidden="true">·</span>
        {lang === 'en' ? (
          <a href="/es/" class="footer-link lang-link">ES</a>
        ) : (
          <a href="/" class="footer-link lang-link">EN</a>
        )}
      </nav>
    </div>
  </div>
</footer>

<style>
  .footer {
    border-top: 1px solid var(--color-bg-tertiary);
    padding: var(--spacing-block) 0;
  }

  .footer-top {
    display: flex;
    align-items: flex-start;
    justify-content: space-between;
    margin-bottom: var(--spacing-element);
    padding-bottom: var(--spacing-element);
    border-bottom: 1px solid var(--color-bg-tertiary);
  }

  .footer-brand {
    display: flex;
    flex-direction: column;
    gap: var(--spacing-tight);
  }

  .brand-word {
    font-family: var(--font-heading);
    font-weight: var(--weight-heading);
    font-size: var(--text-body);
    letter-spacing: var(--tracking-wordmark);
    color: var(--color-text-primary);
  }

  .brand-tag {
    font-family: var(--font-mono);
    font-size: 0.65rem;
    letter-spacing: 0.1em;
    color: var(--color-text-muted);
  }

  .footer-meta {
    display: flex;
    align-items: center;
  }

  .spec-version {
    font-family: var(--font-mono);
    font-size: 0.65rem;
    letter-spacing: 0.1em;
    color: var(--color-text-muted);
    border: 1px solid var(--color-bg-tertiary);
    padding: 3px var(--spacing-tight);
  }

  .footer-bottom {
    display: flex;
    align-items: center;
  }

  .footer-nav {
    display: flex;
    align-items: center;
    gap: var(--spacing-element);
  }

  .footer-link {
    font-family: var(--font-mono);
    font-size: var(--text-caption);
    color: var(--color-text-muted);
    text-decoration: none;
    letter-spacing: 0.04em;
    transition: color var(--duration-fast) var(--easing-linear);
  }

  .footer-link:hover {
    color: var(--color-text-primary);
  }

  .footer-divider {
    color: var(--color-bg-tertiary);
    font-size: var(--text-caption);
  }

  .lang-link {
    border: 1px solid var(--color-bg-tertiary);
    padding: 2px var(--spacing-tight);
    transition: color var(--duration-fast) var(--easing-linear),
                border-color var(--duration-fast) var(--easing-linear);
  }

  .lang-link:hover {
    color: var(--color-text-primary);
    border-color: var(--color-text-muted);
  }

  /* Mobile */
  @media (max-width: 600px) {
    .footer-top {
      flex-direction: column;
      gap: var(--spacing-element);
    }

    .footer-nav {
      flex-wrap: wrap;
      gap: var(--spacing-inline);
    }
  }
</style>
