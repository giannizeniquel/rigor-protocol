---
import { getLangFromUrl, useTranslations } from '../i18n/utils';

const lang = getLangFromUrl(Astro.url);
const t = useTranslations(lang);
---

<footer class="footer">
  <div class="container">
    <div class="footer-grid">
      <div class="column left">
        <p class="brand">{t('footer.brand')}</p>
        <p class="tagline">{t('footer.tagline')}</p>
      </div>
      
      <div class="column center">
        <a href="https://rigor-docs.pages.dev/" class="footer-link" target="_blank" rel="noopener noreferrer">{t('footer.specification')}</a>
        <a href="https://github.com/giannizeniquel/rigor-protocol" class="footer-link" target="_blank" rel="noopener noreferrer">{t('footer.github')}</a>
        <div class="lang-selector">
          {lang === 'en' ? (
            <a href="/es/" class="lang-link">ES</a>
          ) : (
            <a href="/" class="lang-link">EN</a>
          )}
        </div>
      </div>
      
      <div class="column right">
        <p class="version">{t('footer.version')}</p>
      </div>
    </div>
  </div>
</footer>

<style>
  .footer {
    padding: var(--spacing-block) 0;
    border-top: 1px solid var(--color-bg-tertiary);
    margin-top: var(--spacing-section);
  }

  .footer-grid {
    display: grid;
    grid-template-columns: 1fr 1fr 1fr;
    gap: var(--spacing-element);
  }

  .column {
    display: flex;
    flex-direction: column;
  }

  .left {
    align-items: flex-start;
  }

  .center {
    align-items: center;
    gap: var(--spacing-tight);
  }

  .right {
    align-items: flex-end;
  }

  .brand {
    font-family: var(--font-heading);
    font-weight: var(--weight-heading);
    letter-spacing: var(--tracking-wordmark);
    margin-bottom: var(--spacing-tight);
  }

  .tagline {
    color: var(--color-text-muted);
    font-size: var(--text-caption);
  }

  .footer-link {
    color: var(--color-text-primary);
    text-decoration: none;
    font-size: var(--text-caption);
    transition: opacity 150ms linear;
  }

  .footer-link:hover {
    opacity: 0.8;
  }

  .version {
    color: var(--color-text-muted);
    font-size: var(--text-caption);
  }

  .lang-selector {
    margin-top: var(--spacing-tight);
  }

  .lang-link {
    color: var(--color-text-muted);
    text-decoration: none;
    font-size: var(--text-caption);
    transition: opacity 150ms linear;
  }

  .lang-link:hover {
    opacity: 0.8;
  }

  @media (max-width: 768px) {
    .footer-grid {
      grid-template-columns: 1fr;
      text-align: center;
    }

    .left, .center, .right {
      align-items: center;
    }
  }
</style>
