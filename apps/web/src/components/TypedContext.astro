---
import { getLangFromUrl, useTranslations } from '../i18n/utils';

const lang = getLangFromUrl(Astro.url);
const t = useTranslations(lang);
---

<section class="section section--ruled">
  <div class="container">
    <div class="section-header">
      <span class="section-num">08</span>
      <span class="section-rule"></span>
    </div>
    <h2>{t('typedContext.title')}</h2>
    <div class="content">
      <p class="intro">{t('typedContext.intro')}</p>
      <ul class="feature-list">
        <li>{t('typedContext.list.1')}</li>
        <li>{t('typedContext.list.2')}</li>
        <li>{t('typedContext.list.3')}</li>
        <li>{t('typedContext.list.4')}</li>
      </ul>
      <p class="outro">{t('typedContext.outro')}</p>
    </div>
  </div>
</section>

<style>
  .section--ruled {
    padding-top: var(--spacing-section);
    padding-bottom: var(--spacing-section);
  }

  .section-header {
    display: flex;
    align-items: center;
    gap: var(--spacing-inline);
    margin-bottom: var(--spacing-block);
  }

  .section-num {
    font-family: var(--font-mono);
    font-size: 0.7rem;
    color: var(--color-text-muted);
    letter-spacing: 0.14em;
    flex-shrink: 0;
    line-height: 1;
  }

  .section-rule {
    display: block;
    width: 100%;
    height: 1px;
    background-color: var(--color-bg-tertiary);
  }

  h2 {
    font-family: var(--font-heading);
    font-size: var(--text-h2);
    font-weight: var(--weight-heading);
    letter-spacing: var(--tracking-heading);
    margin-bottom: var(--spacing-element);
  }

  .content {
    max-width: 720px;
  }

  .intro {
    font-family: var(--font-body);
    font-size: var(--text-body);
    color: var(--color-text-primary);
    line-height: var(--leading-body);
    margin-bottom: var(--spacing-element);
  }

  .feature-list {
    list-style: none;
    padding: 0;
    margin: var(--spacing-block) 0;
  }

  .feature-list li {
    font-family: var(--font-mono);
    font-size: 0.875rem;
    color: var(--color-text-primary);
    padding: var(--spacing-element) 0;
    padding-left: var(--spacing-inline);
    border-left: 2px solid var(--color-accent);
    margin-bottom: var(--spacing-inline);
  }

  .outro {
    font-family: var(--font-body);
    font-size: var(--text-body);
    color: var(--color-text-muted);
    line-height: var(--leading-body);
    margin-bottom: 0;
  }
</style>
