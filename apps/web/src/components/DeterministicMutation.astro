---
import { getLangFromUrl, useTranslations } from '../i18n/utils';

const lang = getLangFromUrl(Astro.url);
const t = useTranslations(lang);
---

<section class="section section--ruled">
  <div class="container">
    <div class="section-header">
      <span class="section-num">04</span>
      <span class="section-rule"></span>
    </div>
    <h2>{t('deterministicMutation.title')}</h2>
    <div class="content">
      <p class="body">{t('deterministicMutation.body')}</p>
      <div class="guarantees">
        <p class="guarantees-label">{t('deterministicMutation.guarantees')}</p>
      </div>
    </div>
  </div>
</section>

<style>
  .section--ruled {
    padding-top: var(--spacing-section);
    padding-bottom: var(--spacing-section);
  }

  .section-header {
    display: flex;
    align-items: center;
    gap: var(--spacing-inline);
    margin-bottom: var(--spacing-block);
  }

  .section-num {
    font-family: var(--font-mono);
    font-size: 0.7rem;
    color: var(--color-text-muted);
    letter-spacing: 0.14em;
    flex-shrink: 0;
    line-height: 1;
  }

  .section-rule {
    display: block;
    width: 100%;
    height: 1px;
    background-color: var(--color-bg-tertiary);
  }

  h2 {
    font-family: var(--font-heading);
    font-size: var(--text-h2);
    font-weight: var(--weight-heading);
    letter-spacing: var(--tracking-heading);
    margin-bottom: var(--spacing-element);
  }

  .content {
    max-width: 720px;
  }

  .body {
    font-family: var(--font-body);
    font-size: var(--text-body);
    color: var(--color-text-primary);
    line-height: var(--leading-body);
    margin-bottom: var(--spacing-block);
  }

  .guarantees {
    border-left: 2px solid var(--color-accent);
    padding-left: var(--spacing-inline);
  }

  .guarantees-label {
    font-family: var(--font-mono);
    font-size: var(--text-caption);
    color: var(--color-text-muted);
    line-height: var(--leading-body);
    margin-bottom: 0;
  }
</style>
