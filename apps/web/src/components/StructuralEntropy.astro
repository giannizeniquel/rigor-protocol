---
import { getLangFromUrl, useTranslations } from '../i18n/utils';

const lang = getLangFromUrl(Astro.url);
const t = useTranslations(lang);
---

<section class="section section--ruled">
  <div class="container">
    <div class="section-header">
      <span class="section-num">05</span>
      <span class="section-rule"></span>
    </div>
    <h2>{t('structuralEntropy.title')}</h2>

    <div class="definition-block">
      <p class="definition">{t('structuralEntropy.definition')}</p>
    </div>

    <div class="manifestation">
      <p class="manifestation-title">{t('structuralEntropy.manifestationTitle')}</p>
      <ul>
        <li>{t('structuralEntropy.m1')}</li>
        <li>{t('structuralEntropy.m2')}</li>
        <li>{t('structuralEntropy.m3')}</li>
        <li>{t('structuralEntropy.m4')}</li>
      </ul>
      <p class="cumulative">{t('structuralEntropy.cumulative')}</p>
    </div>

    <p class="positioning">{t('structuralEntropy.positioning')}</p>
  </div>
</section>

<style>
  .section--ruled {
    padding-top: var(--spacing-section);
    padding-bottom: var(--spacing-section);
  }

  .section-header {
    display: flex;
    align-items: center;
    gap: var(--spacing-inline);
    margin-bottom: var(--spacing-block);
  }

  .section-num {
    font-family: var(--font-mono);
    font-size: 0.7rem;
    color: var(--color-text-muted);
    letter-spacing: 0.14em;
    flex-shrink: 0;
    line-height: 1;
  }

  .section-rule {
    display: block;
    width: 100%;
    height: 1px;
    background-color: var(--color-bg-tertiary);
  }

  h2 {
    font-family: var(--font-heading);
    font-size: var(--text-h2);
    font-weight: var(--weight-heading);
    letter-spacing: var(--tracking-heading);
    margin-bottom: var(--spacing-block);
  }

  .definition-block {
    border-left: 2px solid var(--color-accent);
    padding-left: var(--spacing-element);
    margin-bottom: var(--spacing-block);
    max-width: 720px;
  }

  .definition {
    font-weight: var(--weight-heading);
    line-height: var(--leading-body);
    margin-bottom: 0;
  }

  .manifestation {
    margin-bottom: var(--spacing-block);
    max-width: 720px;
  }

  .manifestation-title {
    font-size: var(--text-body);
    color: var(--color-text-muted);
    margin-bottom: var(--spacing-element);
  }

  .manifestation ul {
    list-style: none;
    padding: 0;
    margin: 0 0 var(--spacing-element) 0;
    display: grid;
    gap: var(--spacing-tight);
  }

  .manifestation li {
    padding: var(--spacing-tight) var(--spacing-inline);
    border-left: 1px solid var(--color-bg-tertiary);
    font-family: var(--font-mono);
    font-size: var(--text-caption);
    color: var(--color-text-muted);
    letter-spacing: 0.02em;
  }

  .cumulative {
    font-size: var(--text-caption);
    color: var(--color-text-muted);
    margin-bottom: 0;
  }

  .positioning {
    font-weight: var(--weight-heading);
    max-width: 720px;
    border-left: 2px solid var(--color-accent);
    padding-left: var(--spacing-inline);
    margin-bottom: 0;
  }
</style>
