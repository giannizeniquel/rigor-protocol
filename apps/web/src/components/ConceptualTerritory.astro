---
import { getLangFromUrl, useTranslations } from '../i18n/utils';

const lang = getLangFromUrl(Astro.url);
const t = useTranslations(lang);
---

<section class="section section--ruled">
  <div class="container">
    <div class="section-header">
      <span class="section-num">06</span>
      <span class="section-rule"></span>
    </div>
    <h2>{t('conceptualTerritory.title')}</h2>
    <p class="intro">{t('conceptualTerritory.intro')}</p>

    <ul class="territory-list">
      <li>
        <span class="territory-index">01</span>
        {t('conceptualTerritory.list.1')}
      </li>
      <li>
        <span class="territory-index">02</span>
        {t('conceptualTerritory.list.2')}
      </li>
      <li>
        <span class="territory-index">03</span>
        {t('conceptualTerritory.list.3')}
      </li>
      <li>
        <span class="territory-index">04</span>
        {t('conceptualTerritory.list.4')}
      </li>
      <li>
        <span class="territory-index">05</span>
        {t('conceptualTerritory.list.5')}
      </li>
    </ul>

    <p class="closing">{t('conceptualTerritory.closing')}</p>
  </div>
</section>

<style>
  .section--ruled {
    padding-top: var(--spacing-section);
    padding-bottom: var(--spacing-section);
  }

  .section-header {
    display: flex;
    align-items: center;
    gap: var(--spacing-inline);
    margin-bottom: var(--spacing-block);
  }

  .section-num {
    font-family: var(--font-mono);
    font-size: 0.7rem;
    color: var(--color-text-muted);
    letter-spacing: 0.14em;
    flex-shrink: 0;
    line-height: 1;
  }

  .section-rule {
    display: block;
    width: 100%;
    height: 1px;
    background-color: var(--color-bg-tertiary);
  }

  h2 {
    font-family: var(--font-heading);
    font-size: var(--text-h2);
    font-weight: var(--weight-heading);
    letter-spacing: var(--tracking-heading);
    margin-bottom: var(--spacing-element);
  }

  .intro {
    color: var(--color-text-muted);
    margin-bottom: var(--spacing-block);
    max-width: 720px;
  }

  .territory-list {
    list-style: none;
    padding: 0;
    margin-bottom: var(--spacing-block);
    max-width: 720px;
    border: 1px solid var(--color-bg-tertiary);
    border-bottom: none;
  }

  .territory-list li {
    display: flex;
    align-items: center;
    gap: var(--spacing-element);
    padding: var(--spacing-element);
    border-left: 2px solid var(--color-accent);
    border-bottom: 1px solid var(--color-bg-tertiary);
    font-family: var(--font-heading);
    font-size: var(--text-body);
    font-weight: var(--weight-heading);
    color: var(--color-text-primary);
    letter-spacing: var(--tracking-heading);
    transition: background-color var(--duration-fast) var(--easing-linear);
  }

  .territory-list li:hover {
    background-color: var(--color-bg-secondary);
  }

  .territory-index {
    font-family: var(--font-mono);
    font-size: var(--text-caption);
    color: var(--color-text-muted);
    flex-shrink: 0;
    min-width: 24px;
  }

  .closing {
    font-weight: var(--weight-heading);
    color: var(--color-text-muted);
    max-width: 720px;
    font-size: var(--text-caption);
    margin-bottom: 0;
  }
</style>
