---
import { getLangFromUrl, useTranslations } from '../i18n/utils';

const lang = getLangFromUrl(Astro.url);
const t = useTranslations(lang);
---

<section class="section section--ruled">
  <div class="container">
    <div class="section-header">
      <span class="section-num">07</span>
      <span class="section-rule"></span>
    </div>
    <h2>{t('protocolModel.title')}</h2>

    <div class="protocol-layout">

      <!-- Component list: left column -->
      <div class="components">
        <p class="components-intro">{t('protocolModel.componentsTitle')}</p>
        <ul>
          <li>
            <span class="comp-index">01</span>
            <div class="comp-body">
              <span>{t('protocolModel.components.1' as any)}</span>
            </div>
          </li>
          <li>
            <span class="comp-index">02</span>
            <div class="comp-body">
              <span>{t('protocolModel.components.2' as any)}</span>
            </div>
          </li>
          <li>
            <span class="comp-index">03</span>
            <div class="comp-body">
              <span>{t('protocolModel.components.3' as any)}</span>
            </div>
          </li>
          <li>
            <span class="comp-index">04</span>
            <div class="comp-body">
              <span>{t('protocolModel.components.4' as any)}</span>
            </div>
          </li>
          <li>
            <span class="comp-index">05</span>
            <div class="comp-body">
              <span>{t('protocolModel.components.5' as any)}</span>
            </div>
          </li>
        </ul>
      </div>

      <!-- Diagram: right column -->
      <div class="diagram-col" aria-hidden="true">
        <p class="diagram-fig">FIG. 02 — {t('protocolModel.diagramTitle')}</p>
        <div class="diagram-box">
          <svg viewBox="0 0 300 340" fill="none" xmlns="http://www.w3.org/2000/svg">
            <rect x="30" y="10" width="240" height="40" stroke="#F2F2F2" stroke-width="1.5"/>
            <text x="150" y="35" fill="#F2F2F2" font-family="'Space Grotesk', sans-serif" font-size="11" text-anchor="middle" letter-spacing="0.04em">
              {t('protocolModel.flow.humanIntent')}
            </text>

            <path d="M150 50 L150 68" stroke="#A3A3A3" stroke-width="1"/>
            <polygon points="150,68 145,60 155,60" fill="#A3A3A3"/>

            <rect x="10" y="72" width="280" height="40" stroke="#1E3A8A" stroke-width="2"/>
            <rect x="10" y="72" width="4" height="40" fill="#1E3A8A"/>
            <text x="158" y="97" fill="#F2F2F2" font-family="'Space Grotesk', sans-serif" font-size="11" text-anchor="middle" letter-spacing="0.04em">
              {t('protocolModel.flow.specification')}
            </text>

            <path d="M150 112 L150 130" stroke="#A3A3A3" stroke-width="1"/>
            <polygon points="150,130 145,122 155,122" fill="#A3A3A3"/>

            <rect x="50" y="134" width="200" height="40" stroke="#F2F2F2" stroke-width="1.5"/>
            <text x="150" y="159" fill="#F2F2F2" font-family="'Space Grotesk', sans-serif" font-size="11" text-anchor="middle" letter-spacing="0.04em">
              {t('protocolModel.flow.generation')}
            </text>

            <path d="M150 174 L150 192" stroke="#A3A3A3" stroke-width="1"/>
            <polygon points="150,192 145,184 155,184" fill="#A3A3A3"/>

            <rect x="30" y="196" width="240" height="40" stroke="#1E3A8A" stroke-width="2"/>
            <rect x="30" y="196" width="4" height="40" fill="#1E3A8A"/>
            <text x="158" y="221" fill="#F2F2F2" font-family="'Space Grotesk', sans-serif" font-size="11" text-anchor="middle" letter-spacing="0.04em">
              {t('protocolModel.flow.validation')}
            </text>

            <path d="M150 236 L150 254" stroke="#A3A3A3" stroke-width="1"/>
            <polygon points="150,254 145,246 155,246" fill="#A3A3A3"/>

            <rect x="50" y="258" width="200" height="40" stroke="#F2F2F2" stroke-width="1.5"/>
            <text x="150" y="283" fill="#F2F2F2" font-family="'Space Grotesk', sans-serif" font-size="11" text-anchor="middle" letter-spacing="0.04em">
              {t('protocolModel.flow.execution')}
            </text>
          </svg>
        </div>
        <p class="diagram-caption">{t('protocolModel.diagramDescription')}</p>
      </div>

    </div>
  </div>
</section>

<style>
  .section--ruled {
    padding-top: var(--spacing-section);
    padding-bottom: var(--spacing-section);
  }

  .section-header {
    display: flex;
    align-items: center;
    gap: var(--spacing-inline);
    margin-bottom: var(--spacing-block);
  }

  .section-num {
    font-family: var(--font-mono);
    font-size: 0.7rem;
    color: var(--color-text-muted);
    letter-spacing: 0.14em;
    flex-shrink: 0;
    line-height: 1;
  }

  .section-rule {
    display: block;
    width: 100%;
    height: 1px;
    background-color: var(--color-bg-tertiary);
  }

  h2 {
    font-family: var(--font-heading);
    font-size: var(--text-h2);
    font-weight: var(--weight-heading);
    letter-spacing: var(--tracking-heading);
    margin-bottom: var(--spacing-block);
  }

  .protocol-layout {
    display: grid;
    grid-template-columns: 1fr 360px;
    gap: var(--spacing-section);
    align-items: start;
  }

  /* Component list */
  .components-intro {
    font-size: var(--text-caption);
    color: var(--color-text-muted);
    letter-spacing: 0.04em;
    margin-bottom: var(--spacing-element);
  }

  .components ul {
    list-style: none;
    padding: 0;
    display: flex;
    flex-direction: column;
    gap: 0;
  }

  .components li {
    display: flex;
    align-items: flex-start;
    gap: var(--spacing-element);
    border-left: 2px solid var(--color-accent);
    padding: var(--spacing-element) var(--spacing-element);
    border-bottom: 1px solid var(--color-bg-tertiary);
  }

  .components li:last-child {
    border-bottom: none;
  }

  .comp-index {
    font-family: var(--font-mono);
    font-size: var(--text-caption);
    color: var(--color-text-muted);
    flex-shrink: 0;
    line-height: 1.6;
  }

  .comp-body {
    display: flex;
    flex-direction: column;
    gap: 4px;
  }

  .comp-body strong {
    font-family: var(--font-heading);
    font-weight: var(--weight-heading);
    font-size: var(--text-body);
    color: var(--color-text-primary);
    letter-spacing: 0.02em;
  }

  .comp-body span {
    font-size: var(--text-caption);
    color: var(--color-text-muted);
    line-height: var(--leading-caption);
  }

  /* Diagram column */
  .diagram-col {
    display: flex;
    flex-direction: column;
  }

  .diagram-fig {
    font-family: var(--font-mono);
    font-size: 0.7rem;
    color: var(--color-text-muted);
    letter-spacing: 0.1em;
    text-transform: uppercase;
    margin-bottom: var(--spacing-inline);
  }

  .diagram-box {
    border: 1px solid var(--color-bg-tertiary);
    background-color: var(--color-bg-secondary);
    padding: var(--spacing-element);
    display: flex;
    justify-content: center;
    align-items: center;
  }

  .diagram-box svg {
    width: 100%;
    max-width: 300px;
    height: auto;
  }

  .diagram-caption {
    font-family: var(--font-mono);
    font-size: 0.7rem;
    color: var(--color-text-muted);
    margin-top: var(--spacing-inline);
    line-height: var(--leading-caption);
    margin-bottom: 0;
  }

  /* Mobile */
  @media (max-width: 900px) {
    .protocol-layout {
      grid-template-columns: 1fr;
      gap: var(--spacing-block);
    }

    .diagram-col {
      order: -1;
    }
  }
</style>
