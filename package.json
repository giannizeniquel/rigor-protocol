{
  "name": "rigor-monorepo",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "packageManager": "npm@10.0.0",
  "workspaces": [
    "apps/*",
    "packages/*"
  ],
  "scripts": {
    "dev": "turbo run dev",
    "build": "turbo run build",
    "build:web": "turbo run build --filter=web",
    "build:docs": "turbo run build --filter=docs",
    "test": "playwright test",
    "test:e2e": "playwright test tests/e2e",
    "test:visual": "playwright test tests/visual",
    "test:accessibility": "playwright test tests/accessibility",
    "test:visual:update": "playwright test tests/visual --update-snapshots",
    "lighthouse": "lighthouse http://localhost:4321 --output json --output html --output-path ./lighthouse-report.html",
    "lighthouse:ci": "lhci autorun",
    "agent": "bash agents/testing/testing-agent.sh",
    "agent:test": "bash agents/testing/testing-agent.sh",
    "agent:test:e2e": "bash agents/testing/e2e-agent.sh",
    "agent:test:visual": "bash agents/testing/visual-agent.sh",
    "agent:test:visual:update": "UPDATE_VISUAL=true bash agents/testing/visual-agent.sh",
    "agent:test:accessibility": "bash agents/testing/accessibility-agent.sh",
    "agent:build": "bash agents/build/build-orchestrator.sh",
    "agent:build:all": "bash agents/build/build-agent.sh all",
    "agent:build:web": "bash agents/build/build-agent.sh web",
    "agent:build:docs": "bash agents/build/build-agent.sh docs",
    "agent:lint": "AUTO_FIX=false bash agents/build/lint-agent.sh",
    "agent:lint:fix": "AUTO_FIX=true bash agents/build/lint-agent.sh",
    "agent:deps": "bash agents/build/deps-agent.sh",
    "agent:perf": "bash agents/performance/performance-agent.sh",
    "agent:perf:lighthouse": "bash agents/performance/lighthouse-agent.sh",
    "agent:perf:bundle": "bash agents/performance/bundle-agent.sh",
    "agent:i18n": "bash agents/i18n/i18n-agent.sh",
    "agent:i18n:translation": "bash agents/i18n/translation-agent.sh",
    "agent:i18n:consistency": "bash agents/i18n/consistency-agent.sh",
    "agent:all": "bash agents/build/build-orchestrator.sh all && bash agents/testing/testing-agent.sh all && bash agents/performance/performance-agent.sh all && bash agents/i18n/i18n-agent.sh all"
  },
  "devDependencies": {
    "@axe-core/playwright": "^4.11.1",
    "@playwright/test": "^1.58.2",
    "axe-core": "^4.11.1",
    "lighthouse": "^12.8.2",
    "playwright": "^1.58.2",
    "turbo": "^2.8.9"
  }
}
